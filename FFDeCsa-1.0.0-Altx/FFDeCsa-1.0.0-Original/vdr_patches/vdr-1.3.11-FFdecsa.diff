+bool cTSBuffer::Release(void)
+{ 
+  if (Collected() >= TS_SIZE) {
+     uchar *p = buf + tsRelease;
+     if (*p != TS_SYNC_BYTE) {
+        esyslog("ERROR: (release) not sync'ed to TS packet on device %d", cardIndex);
+        int tsMax = tsRelease < tsCollect ? tsCollect : size;
+        for (int i = tsRelease; i < tsMax; i++) {
+            if (buf[i] == TS_SYNC_BYTE) {
+               esyslog("ERROR: (release) skipped %d bytes to sync on TS packet on device %d", i - tsRelease, cardIndex);
+               tsRelease = i;
+               return true;
+               }
+            }
+        if ((tsRelease = tsMax) >= size)
+           tsRelease = 0;
+        return true;
+        }
+     if (tsRelease + TS_SIZE > size) {
+        // the packet rolled over the buffer boundary, so let's fetch the rest from the beginning (which MUST be there, since Collected() >= TS_SIZE)
+        int rest = TS_SIZE - (size - tsRelease);
+        // no need to move data, so no memcpy(buf + size, buf, rest);
+        tsRelease = rest;
+        }
+     else if ((tsRelease += TS_SIZE) >= size)
+        tsRelease = 0;
+     return true;
+     }
+  return false;
