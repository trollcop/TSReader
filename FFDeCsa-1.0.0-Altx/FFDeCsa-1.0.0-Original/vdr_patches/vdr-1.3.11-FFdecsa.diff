--- vdr-1.3.11_p0/csa.c	1970-01-01 01:00:00.000000000 +0100
+++ vdr-1.3.11_p0_p1/csa.c	2004-09-17 14:47:49.711756806 +0200
@@ -0,0 +1,102 @@
+/*
+ * csa.c:
+ *
+ */
+
+#include <stdio.h>
+#include <string.h>
+#include "csa.h"
+
+//#define DEBUG(x...) printf(x)
+#define DEBUG(x...)
+//#define DEBUGFLUSH fflush(stdout)
+#define DEBUGFLUSH
+
+
+#include "FFdecsa/FFdecsa.h"
+
+cCSA::cCSA(void)
+{
+  force_dequeueing=false;
+  even_is_queued=odd_is_queued=false;
+  memset(odd_ck,0,sizeof(odd_ck));
+  memset(even_ck,0,sizeof(even_ck));
+  memset(queued_odd_ck,0,sizeof(queued_odd_ck));
+  memset(queued_even_ck,0,sizeof(queued_even_ck));
+}
+
+void cCSA::SetDescr(ca_descr_t *ca_descr)
+{
+  if(ca_descr->parity==2222) { // flush keys command!
+    DEBUG("csa: flushing keys -----\n");
+    force_dequeueing=true;
+    }
+  else if(ca_descr->parity==0) { // even key
+    memcpy(queued_even_ck,ca_descr->cw,8);
+    even_is_queued=true;
+    DEBUG("csa: queued even key\n");
+    }
+  else {                    // odd key
+    memcpy(queued_odd_ck,ca_descr->cw,8);
+    odd_is_queued=true;
+    DEBUG("csa: \t\t\t\tqueued odd key\n");
+    }
+}
+
+int cCSA::DecryptCluster(unsigned char **cluster)
+{
+  unsigned char **clu=cluster;
+  unsigned char *pkt;
+  bool even_is_used,odd_is_used;
+  int done;
+
+  pkt=*clu;
+  even_is_used=odd_is_used=false;
+  while(1){
+    if(pkt==NULL) break;
+    if(pkt>=*(clu+1)){
+      clu+=2;
+      pkt=*clu;
+      continue;
+    }
+    // process packet
+    if((pkt[3]&0xC0)==0x80) { // even
+      even_is_used=true;
+    }
+    if((pkt[3]&0xC0)==0xC0) { // odd
+      odd_is_used=true;
+    }
+    // increment
+    pkt+=188;
+  }
+#if 1
+  if(even_is_queued&&(!even_is_used||force_dequeueing)) {
+    DEBUG("csa: dequeued even key\n");
+    if(force_dequeueing) DEBUG("csa: forced\n");
+    memcpy(even_ck,queued_even_ck,8);
+    set_control_words(even_ck,odd_ck);
+    even_is_queued=false;
+  }
+  if(odd_is_queued&&(!odd_is_used||force_dequeueing)) {
+    DEBUG("csa: \t\t\t\tdequeued odd key\n");
+    if(force_dequeueing) DEBUG("csa: \t\t\t\tforced\n");
+    memcpy(odd_ck,queued_odd_ck,8);
+    set_control_words(even_ck,odd_ck);
+    odd_is_queued=false;
+  }
+  force_dequeueing=false;
+#endif
+  if(even_is_queued) {
+    DEBUG(" !E! ");
+  }
+  if(odd_is_queued) {
+    DEBUG(" !O! ");
+  }
+  if(even_is_used) DEBUG("E");
+  if(odd_is_used) DEBUG("O");
+  done=decrypt_packets(cluster);
+  DEBUG("/%i ",done);
+  DEBUGFLUSH;
+  return done;
+}
+
