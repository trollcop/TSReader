[version]
Signature="$CHICAGO$"
Compatible  = 1
ClassGUID   = {4d36e972-e325-11ce-bfc1-08002be10318}
Class=Net
provider=%V_TECHNOTREND%
DriverVer   = 12/06/2005,2.5.0.5

[Manufacturer]
%V_TECHNOTREND%=TECHNOTREND

[ControlFlags]
ExcludeFromSelect     = PCI\VEN_1131&DEV_7146&SUBSYS_100313c2
