    LTEXT           "Split Filename Settings",IDC_TITLE,0,0,321,14
    EDITTEXT        IDC_FORMAT_STRING,62,138,160,12,ES_AUTOHSCROLL
    LTEXT           "This software uses a 'C'-style formatting string to set the name of the files generated when splitting files because of their size or record time.",
                    IDC_STATIC,10,18,221,17
    LTEXT           "The variables are prefixed with a % sign. Numeric values may contain a size field and are as follows:",
                    IDC_STATIC,10,35,216,16
    LTEXT           "f - filename\ne - file extension\nn - file number\ny - year\nm - month\nv - event name",
                    IDC_STATIC,49,55,72,49
    LTEXT           "d - day\nh - hour\ni - minute\ns - second\n% - percent sign",
                    IDC_STATIC,129,55,72,42
    LTEXT           "Examples:",IDC_STATIC,10,104,166,8
    LTEXT           "%f-%5n.%e - recording-00001.ts\n%f-%4y%2m%2d-%2h%2i.%e - recording-20030404-1000.ts",
                    IDC_STATIC,28,115,191,16
    RTEXT           "Format String",IDC_STATIC,0,140,41,8
    RTEXT           "Sample Filename",IDC_STATIC,0,154,53,8
    EDITTEXT        IDC_FORMAT_SAMPLE,62,153,160,12,ES_AUTOHSCROLL | 
