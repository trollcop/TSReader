        BLOCK "040904b0"
        BEGIN
            VALUE "Comments", "\0"
            VALUE "CompanyName", "COOLSTF.com Inc.\0"
            VALUE "FileDescription", "TSReader\0"
            VALUE "FileVersion", "2.8.53h-memorial\0"
            VALUE "InternalName", "TSReader\0"
