    CONTROL         "Scope-style audio thumbnails enabled",
                    IDC_AUDIO_THUMBNAILS_ENABLED,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,9,8,133,8
    CONTROL         "Song title thumbnail generator enabled",
                    IDC_TITLE_PARSER_ENABLED,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,9,23,155,8
    EDITTEXT        IDC_AUDIO_TITLE_PMT_TYPE,100,36,25,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_AUDIO_TITLE_MPEG_TABLE_NUMBER,100,50,26,13,
                    ES_AUTOHSCROLL | NOT WS_VISIBLE
    DEFPUSHBUTTON   "OK",IDOK,74,73,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,129,73,50,14
    RTEXT           "PMT Stream Type",IDC_STATIC,20,38,68,8
    RTEXT           "MPEG Table Number",IDC_STATIC,20,51,68,8,NOT WS_VISIBLE
    LTEXT           "IDC_AUDIO_THUMBNAIL_BASE",IDC_AUDIO_THUMBNAIL_BASE,130,
                    38,44,8
    LTEXT           "IDC_AUDIO_THUMBNAIL_BASE",IDC_AUDIO_THUMBNAIL_BASE2,130,
                    51,44,8,NOT WS_VISIBLE
END


