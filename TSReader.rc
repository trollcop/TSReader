    PUSHBUTTON      "Cancel",IDCANCEL,186,192,50,14
    LTEXT           "uses a 'C'-style formatting string to set the name of the files generated when splitting files because of their size or record time.",
                    IDC_SPLIT_INFO_CAPTION,10,13,221,17
    LTEXT           "The variables are prefixed with a % sign. Numeric values may contain a size field and are as follows:",
                    IDC_STATIC,10,32,216,16
    LTEXT           "f - filename\ne - file extension\nn - file number\ny - year (4 digit)\nm - month\nd - day\n",
                    IDC_STATIC,49,53,72,49
    LTEXT           "h - hour\ni - minute\ns - second\n% - percent sign\nv - event name",
                    IDC_STATIC,129,53,72,53
    LTEXT           "Examples:",IDC_STATIC,10,105,166,8
    LTEXT           "%f-%5n.%e - recording-00001.ts\n%f-%4y%2m%2d-%2h%2i.%e - recording-20030404-1000.ts",
                    IDC_STATIC,28,119,191,16
    GROUPBOX        "Information",IDC_STATIC,3,1,234,138
    GROUPBOX        "Current Setting",IDC_STATIC,3,144,234,44
    RTEXT           "Format String",IDC_STATIC,8,157,57,8
    RTEXT           "Sample Filename",IDC_STATIC,8,173,57,8
    EDITTEXT        IDC_FORMAT_SAMPLE,71,171,160,12,ES_AUTOHSCROLL | 
                    ES_READONLY
END

