/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAIN MENU DISCARDABLE 
BEGIN
    POPUP "File"
    BEGIN
        MENUITEM "CI-CAM Menu...",              ID_FILE_CICAMMENU
        MENUITEM "DiSEqC Positioner...",        ID_FILE_DISEQCPOSITIONER
        MENUITEM SEPARATOR
        MENUITEM "Restart Source...\tAlt+R",    ID_FILE_RESTART_SOURCE
        MENUITEM "Select Source...",            ID_FILE_SELECTSOURCE
        MENUITEM "Stop Source",                 ID_FILE_STOPSOURCE
        MENUITEM SEPARATOR
        MENUITEM "Define manual channels...\tAlt+M", 
                                                ID_FILE_DEFINEMANUALCHANNELS
        MENUITEM "Load manual channels...",     ID_FILE_LOADMANUALCHANNELS
        MENUITEM "Load PID list...",            ID_FILE_LOADPIDLIST
        MENUITEM "Save manual channels...",     ID_FILE_SAVEMANUALCHANNELS
        MENUITEM SEPARATOR
        POPUP "Import Satellite Lists"
        BEGIN
            MENUITEM "Import CSV...",               ID_FILE_IMPORTSATELLITELISTS_IMPORTCSV

            MENUITEM "Import SDX...",               ID_FILE_IMPORTSATELLITELISTS_IMPORTSDX

        END
        MENUITEM SEPARATOR
