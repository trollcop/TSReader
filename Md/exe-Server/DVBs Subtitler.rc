/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 272, 146
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "DVBs Subtitler help/about"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,205,113,51,20
    LTEXT           "How to use:",-1,13,20,117,9
    LTEXT           "- prepare subtitle file in MicroDVD format",-1,13,28,
                    246,9
    LTEXT           "- start MD, switch to proper channel  and press 'J' on keyboard",
                    -1,13,44,246,9
    LTEXT           "- start DVBs subtitler and select prepared subtitle file (MicroDVD format)",
                    -1,13,53,246,9
    LTEXT           "- press ""Next"" button to jump to the first title",-1,
                    13,61,246,9
    LTEXT           "- when the first subtitle is to be displayed, press ""Start/Stop"" button",
                    -1,13,77,246,9
    LTEXT           "- fine tune syncronisation using ""-30s"", ""-25f"", ""-5f""... buttons",
                    -1,13,85,246,9
    LTEXT           "- find out what for are the other buttons ;-)",-1,13,93,
                    246,9
    LTEXT           "Special thanks to Espresso for Multidec and MDExtern example. ",
                    -1,13,113,188,20,WS_BORDER
    RTEXT           "v1.04 by dpanijan@yahoo.com",-1,157,17,102,9,
                    WS_DISABLED
    LTEXT           "- be sure that Sub82cli.dll is in Multidec folder",-1,
                    13,36,246,9
    GROUPBOX        "Stand alone application for serving subtitles to MultiDec",
                    -1,7,7,258,132
    LTEXT           "- press 'J' to turn off subtitles (when the movie is over)",
                    -1,13,101,246,9
    LTEXT           "- don't touch Output, just leave it as is (C:\\SubData.txt)",
                    -1,13,69,246,9
END


