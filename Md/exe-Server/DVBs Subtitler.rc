IDD_DVBSSUBTITLER_DIALOG DIALOGEX 0, 0, 263, 175
STYLE DS_MODALFRAME | WS_MINIMIZEBOX | WS_POPUP | WS_VISIBLE | WS_CAPTION | 
    WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "DVBs Subtitler v1.04"
FONT 8, "MS Sans Serif", 0, 0, 0x1
BEGIN
    PUSHBUTTON      "E&xit",ID_Exit,212,50,44,12,NOT WS_TABSTOP
    LTEXT           "Start frame",IDC_STATIC,14,9,38,8
    LTEXT           "Expire frame",IDC_STATIC,14,22,41,10
    LTEXT           "1st subtitle",IDC_STATIC,16,37,37,8
    LTEXT           "2nd subtitle",IDC_STATIC,16,52,37,8,0,0,HIDC_STATIC
    EDITTEXT        IDC_StartFrame,57,6,34,12,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    EDITTEXT        IDC_ExpireFrame,57,20,34,12,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    EDITTEXT        IDC_Subtitle1,57,35,150,12,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    EDITTEXT        IDC_Subtitle2,57,50,150,12,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    LTEXT           "Current frame",IDC_STATIC,7,70,45,11
    EDITTEXT        IDC_CurrentFrame,57,67,39,13,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    PUSHBUTTON      "Subtitle File",IDC_SubtitleFileselect,212,6,44,13,NOT 
                    WS_TABSTOP
    DEFPUSHBUTTON   "&Start/Pause",IDC_Start,7,116,41,18,NOT WS_TABSTOP
    PUSHBUTTON      "&Reset",IDC_Stop,49,116,22,18,NOT WS_TABSTOP
    PUSHBUTTON      "&-25f",IDC_Minus25,136,116,24,18,NOT WS_TABSTOP
    PUSHBUTTON      "-5f",IDC_Minus5,160,116,24,18,NOT WS_TABSTOP
    PUSHBUTTON      "+5f",IDC_Plus5,184,116,24,18,NOT WS_TABSTOP
    PUSHBUTTON      "&+25f",IDC_Plus25,208,116,24,18,NOT WS_TABSTOP
    LTEXT           "Movie time",IDC_STATIC,7,84,45,10
    EDITTEXT        IDC_MovieTime,57,82,39,13,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    LTEXT           "Subtitle",IDC_STATIC,93,6,25,8
    LTEXT           "System Time",IDC_STATIC,7,100,44,10
    EDITTEXT        IDC_SubtitleFileName,123,6,84,12,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    EDITTEXT        IDC_CurrentTime,57,98,54,13,ES_AUTOHSCROLL | NOT 
                    WS_TABSTOP
    PUSHBUTTON      "+30s",IDC_Plus6,232,116,24,18,NOT WS_TABSTOP
    PUSHBUTTON      "-30s",IDC_Minus26,112,116,24,18,NOT WS_TABSTOP
    CONTROL         "Slider1",IDC_SLIDER,"msctls_trackbar32",TBS_BOTH,98,70,
                    158,26
    PUSHBUTTON      "&Next",IDC_NEXT,91,116,20,18,NOT WS_TABSTOP
    EDITTEXT        IDC_OSD2,7,154,249,13,ES_AUTOHSCROLL | NOT WS_TABSTOP
    EDITTEXT        IDC_OSD1,7,137,249,13,ES_AUTOHSCROLL | NOT WS_TABSTOP
    PUSHBUTTON      "Output",IDC_OUTPUT_FILE,212,20,44,13,NOT WS_TABSTOP
    LTEXT           "Time offset (minutes)",IDC_STATIC,129,101,65,9
    EDITTEXT        IDC_OFFSET,199,97,57,14,ES_AUTOHSCROLL | NOT WS_TABSTOP
    LTEXT           "Output",IDC_STATIC,95,22,27,11
    EDITTEXT        IDC_OUTPUT,123,21,84,12,ES_AUTOHSCROLL | NOT WS_TABSTOP
    LTEXT           "v1.04 dpanijan@yahoo.com 2002",IDC_STATIC,148,167,108,8,
                    WS_DISABLED | NOT WS_GROUP
    PUSHBUTTON      "Help/About",IDC_BUTTON1,212,35,44,12,NOT WS_TABSTOP
    PUSHBUTTON      "&Prev",IDC_PREV,71,116,20,18,NOT WS_TABSTOP
END


