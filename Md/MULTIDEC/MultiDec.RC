SAACARDSET DIALOG DISCARDABLE  22, 17, 217, 263
STYLE DS_MODALFRAME | WS_CAPTION | WS_SYSMENU
CAPTION "SAA7146 Bootoptionen"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL         "Optimiertes Umschalten",IDC_CHECK1,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,3,5,189,8
    LTEXT           "Diese Option kann  die Umschaltzeiten ( und Scanzeiten ) deutlich reduzieren.\nDabei werden nur noch die Zustands-Änderungen an die DVB-Karte weitergegeben. Ob es mit allen Karten und\nDiSEqC geht, kann ich nicht sagen.\nDaher ist diese Option abschaltbar.",
                    IDC_TEXT1,21,15,186,49
    CONTROL         "Optimierter DVB-BOOT",IDC_CHECK3,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,3,66,189,8
    LTEXT           "Diese Option kann die Ladezeiten deutlich reduzieren.\nOb es mit allen Karten  geht, kann ich nicht sagen.\nDaher ist diese Option abschaltbar.",
                    IDC_TEXT6,21,76,186,25
    CONTROL         "Karten-Reset beim Laden nicht durchführen!",IDC_CHECK2,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,3,103,155,10
    LTEXT           "Es kommt ( bei mir ) häufig zum Hängen des gesamten PCI-Busses, ausgelöst durch das Reset beim Laden der SAA-Karte ( auch bei der TT-Software ) !!\nDiese Reset wird nun nicht durchgefüht! \nBooten der DVB-Hardware ist schneller,",
                    IDC_STATIC,21,115,180,42
    LTEXT           "Directory mit der Firmware.\n( Dateien DPRAM , BOOT_UP-AXF und ROOT ) ",
                    IDC_STATIC,7,212,197,18
    EDITTEXT        IDC_EDIT1,4,231,185,12,ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,5,247,60,14,WS_GROUP
    DEFPUSHBUTTON   "Ende",IDCANCEL,153,247,61,14,WS_GROUP
END

