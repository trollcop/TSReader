    LTEXT           "Playing",IDC_STATIC,105,45,24,8
    LTEXT           "AT20",IDC_STATIC,19,58,18,8
    LTEXT           "AT30",IDC_STATIC,19,67,18,8
    LTEXT           "AT40",IDC_STATIC,19,76,18,8
    LTEXT           "AT200",IDC_STATIC,19,85,22,8
    LTEXT           "AT300",IDC_STATIC,19,95,22,8
    LTEXT           "AT400",IDC_STATIC,19,104,22,8
