    LTEXT           "x",IDC_STATIC,66,74,8,8
    LTEXT           "x",IDC_STATIC,117,74,8,8
    LTEXT           "x",IDC_STATIC,66,84,8,8
    LTEXT           "x",IDC_STATIC,117,92,8,8
    LTEXT           "x",IDC_STATIC,66,104,8,8
    LTEXT           "x",IDC_STATIC,117,104,8,8
    LTEXT           "x",IDC_STATIC,117,113,8,8
    LTEXT           "x",IDC_STATIC,117,121,8,8
    LTEXT           "x",IDC_STATIC,117,130,8,8
    GROUPBOX        "",IDC_STATIC,13,39,122,126
    LTEXT           "All devices are setup for a serial DVB input or output.\r\n\r\nRecording :\r\nGets a 1MB data packet from the board and show the 1ste 10 bytes.\r\n\r\nPlay:\r\nSofware generates a stream of 0-packets and sends it to the board.",
                    IDC_STATIC,145,44,71,125
    LTEXT           "x = supported",IDC_STATIC,88,154,44,8
END

IDD_DTV_TEST_DIALOG DIALOGEX 0, 0, 320, 266
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "API demo"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "Close",IDOK,260,7,50,14
    PUSHBUTTON      "Start",IDC_STARTBTN,14,92,50,14
    PUSHBUTTON      "Stop",IDC_STOPBTN,66,92,50,14
    LTEXT           "Data :",IDC_STATIC,13,140,20,8
    LTEXT           "Filename :",IDC_STATIC,13,25,33,8
    LTEXT           "--",IDC_STATICFILENAME,49,26,205,8
    LTEXT           "Boardname :",IDC_STATIC,13,35,41,8
    LTEXT           "--",IDC_STATICBOARDNAME,58,35,198,8
    LTEXT           "Bitrate :",IDC_STATIC,13,54,25,8
    LTEXT           "Data Error :",IDC_STATIC,13,65,37,8
    LTEXT           "Sync Loss :",IDC_STATIC,13,75,38,8
    LTEXT           "--",IDC_STATICBITRATE,44,55,75,8
    LTEXT           "--",IDC_STATICDATAERR,56,66,88,8
    LTEXT           "--",IDC_STATICSYNCLOSS,54,75,90,8
    CONTROL         "List1",IDC_DATALIST,"SysListView32",LVS_REPORT | 
                    WS_BORDER | WS_TABSTOP,16,150,290,101
    LTEXT           "Number of bytes read :",IDC_STATIC,13,112,72,8
    LTEXT           "--",IDC_STATICBYTESREAD,93,112,51,8
    LTEXT           "Number of read cycles :",IDC_STATIC,13,123,76,8
    LTEXT           "--",IDC_STATICREADCYCLES,96,123,43,8
    GROUPBOX        "Mode",IDC_STATIC,213,49,89,58
    CONTROL         "None",IDC_RECPLAYMODE,"Button",BS_AUTORADIOBUTTON | 
                    WS_GROUP,221,66,33,10
    CONTROL         "Record",IDC_RECRADIO,"Button",BS_AUTORADIOBUTTON,221,78,
                    39,10
    CONTROL         "Play (0 packets)",IDC_PLAYRADIO,"Button",
                    BS_AUTORADIOBUTTON,221,91,67,10
    LTEXT           "(Shows only the fist 10 bytes from the Packet)",
                    IDC_STATIC,43,140,144,8
    PUSHBUTTON      "Reset",IDC_RESETBTN,118,92,50,14
END


