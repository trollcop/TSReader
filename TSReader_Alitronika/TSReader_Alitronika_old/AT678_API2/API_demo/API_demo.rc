IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 235, 209
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About API demo"
FONT 8, "MS Sans Serif"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,11,21,20
    LTEXT           "API demo Version 1.0",IDC_STATIC,40,10,119,8,
                    SS_NOPREFIX
